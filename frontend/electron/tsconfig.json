{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": ".",
    "rootDir": "."
  },
  "include": ["main.ts", "backend-manager.ts", "ipc/**/*.ts", "services/**/*.ts", "types/**/*.ts", "utils/**/*.ts"],
  "exclude": ["node_modules"]
}
