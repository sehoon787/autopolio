{
  "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
  "appId": "com.autopolio.app",
  "productName": "Autopolio",
  "copyright": "Copyright © 2026 Autopolio",
  "directories": {
    "buildResources": "build",
    "output": "release"
  },
  "files": [
    "dist/**/*",
    "electron/**/*.js",
    "package.json"
  ],
  "extraResources": [
    {
      "from": "_electron_api/api",
      "to": "api",
      "filter": [
        "**/*",
        "!**/*.py",
        "!**/__pycache__",
        "!**/*.pyo",
        "!**/.git",
        "!**/tests",
        "!**/.pytest_cache"
      ]
    },
    {
      "from": "_electron_api/config",
      "to": "config",
      "filter": ["**/*"]
    },
    {
      "from": "_electron_api/data/platform_templates",
      "to": "data/platform_templates",
      "filter": ["**/*"]
    },
    {
      "from": "_electron_api/data/templates",
      "to": "data/templates",
      "filter": ["**/*"]
    },
    {
      "from": "build/build-info.json",
      "to": "build-info.json"
    }
  ],
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ],
    "icon": "build/icon.ico",
    "artifactName": "${productName}-Setup-${version}-${arch}.${ext}",
    "extraResources": [
      {
        "from": "python-runtime/win32-x64/python",
        "to": "python"
      },
      {
        "from": "python-runtime/win32-x64/site-packages",
        "to": "site-packages"
      }
    ]
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "deleteAppDataOnUninstall": false,
    "installerIcon": "build/icon.ico",
    "uninstallerIcon": "build/icon.ico",
    "installerHeaderIcon": "build/icon.ico",
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "Autopolio"
  },
  "mac": {
    "target": [
      {
        "target": "dmg",
        "arch": ["arm64"]
      }
    ],
    "icon": "build/icon.icns",
    "category": "public.app-category.productivity",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "hardenedRuntime": true,
    "gatekeeperAssess": false,
    "extraResources": [
      {
        "from": "python-runtime/darwin-${arch}/python",
        "to": "python"
      },
      {
        "from": "python-runtime/darwin-${arch}/site-packages",
        "to": "site-packages"
      }
    ]
  },
  "dmg": {
    "contents": [
      {
        "x": 130,
        "y": 220
      },
      {
        "x": 410,
        "y": 220,
        "type": "link",
        "path": "/Applications"
      }
    ],
    "window": {
      "width": 540,
      "height": 380
    }
  },
  "linux": {
    "target": [
      {
        "target": "AppImage",
        "arch": ["x64"]
      },
      {
        "target": "deb",
        "arch": ["x64"]
      }
    ],
    "icon": "build/icons",
    "category": "Office",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "extraResources": [
      {
        "from": "python-runtime/linux-x64/python",
        "to": "python"
      },
      {
        "from": "python-runtime/linux-x64/site-packages",
        "to": "site-packages"
      }
    ]
  },
  "publish": null
}
