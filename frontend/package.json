{
  "name": "autopolio-frontend",
  "private": true,
  "version": "1.23.1",
  "description": "Portfolio and Resume Automation Platform",
  "license": "UNLICENSED",
  "author": "Sehoon Kim",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3035 && tsc -p electron/tsconfig.json && electron .\"",
    "prepare:electron-api": "python3 scripts/prepare-electron-api.py",
    "electron:build": "npm run prepare:electron-api && node -e \"fs=require('fs');path=require('path');fs.mkdirSync('build',{recursive:true});fs.writeFileSync('build/build-info.json',JSON.stringify({sourceProjectRoot:path.resolve('..')}))\" && tsc && cross-env ELECTRON_BUILD=true vite build && tsc -p electron/tsconfig.json",
    "electron:build:win": "npm run electron:build && electron-builder --win",
    "electron:build:mac": "npm run electron:build && electron-builder --mac",
    "electron:build:linux": "npm run electron:build && electron-builder --linux",
    "python:download": "node scripts/download-python.cjs",
    "python:download:win": "node scripts/download-python.cjs --win",
    "python:download:mac": "node scripts/download-python.cjs --mac",
    "python:download:linux": "node scripts/download-python.cjs --linux",
    "python:download:all": "node scripts/download-python.cjs --all",
    "package:win": "npm run python:download:win && npm run electron:build:win",
    "package:mac": "npm run python:download:mac && npm run electron:build:mac",
    "package:linux": "npm run python:download:linux && npm run electron:build:linux"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@formkit/auto-animate": "^0.9.0",
    "@hookform/resolvers": "^3.9.0",
    "@radix-ui/react-accordion": "^1.2.0",
    "@radix-ui/react-alert-dialog": "^1.1.1",
    "@radix-ui/react-checkbox": "^1.1.1",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.1",
    "@radix-ui/react-dropdown-menu": "^2.1.1",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.0",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.1.1",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.1",
    "@radix-ui/react-tooltip": "^1.1.2",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-virtual": "^3.13.21",
    "axios": "^1.13.6",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "electron-serve": "^3.0.1",
    "i18next": "^25.8.14",
    "js-yaml": "^4.1.0",
    "lucide-react": "^0.577.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.71.2",
    "react-i18next": "^16.5.6",
    "react-markdown": "^9.0.1",
    "react-resizable-panels": "^4.7.2",
    "react-router-dom": "^6.26.2",
    "simple-icons": "^16.11.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.23.8",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.3.5",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.5.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "eslint": "^9.10.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.5.2",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.5.8",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.11",
    "tar": "^7.5.11",
    "typescript": "^5.6.2",
    "vite": "^5.4.5",
    "wait-on": "^9.0.4"
  }
}
