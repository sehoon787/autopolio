# Autopolio Configuration
#
# 포트/URL/CORS는 config/runtime.yaml에서 자동 계산됨 — 여기서 설정 금지
# 모델명은 api/config.py에 기본값 설정됨 — 필요시만 override
#
# 포트 구조 (runtime.yaml):
#   로컬 dev:  Frontend=3035, API=8085
#   Docker:    Frontend=3035→3000, API=8085→8000 (외부→컨테이너)

# =============================================================================
# Core
# =============================================================================

# Database (SQLite for local, PostgreSQL via Docker for production)
DATABASE_URL=sqlite+aiosqlite:///./data/autopolio.db

# PostgreSQL (Docker only — ignored when using SQLite)
POSTGRES_USER=autopolio
POSTGRES_PASSWORD=autopolio
POSTGRES_DB=autopolio

# Database migrations (set to true in Docker/production to use Alembic)
ENABLE_MIGRATIONS=false

# Encryption Key (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=your-fernet-key-here

# GitHub OAuth App
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# =============================================================================
# API Provider Keys (서버 LLM 호출용 — 분석, 요약, 문서 생성 등)
# =============================================================================

LLM_PROVIDER=gemini

# Anthropic API
ANTHROPIC_API_KEY=

# Google Gemini API
GEMINI_API_KEY=

# OpenAI API
OPENAI_API_KEY=

# =============================================================================
# CLI Tool Keys (CLI 서브프로세스 인증용 — API 키와 별도 관리)
# =============================================================================

# Claude Code CLI  (Anthropic 키 사용)
CLAUDE_CODE_API_KEY=

# Gemini CLI        (Google 키 사용, GEMINI_API_KEY와 동일 키 사용 가능)
GEMINI_CLI_API_KEY=

# Codex CLI         (OpenAI 키 사용)
CODEX_API_KEY=

# =============================================================================
# GitHub Actions Secrets (로컬에서는 사용 안 됨, gh secret set 용 참조)
# 설정법: gh secret set <KEY> --body "<VALUE>"
# 상세 발급 절차: .github/WORKFLOWS.md 참조
# =============================================================================

# --- CI/CD (ci.yml) ---
# ENCRYPTION_KEY: 위 로컬용과 동일한 값 사용 (gh secret에도 설정 필요)
# GITHUB_TOKEN: 자동 제공 (설정 불필요)

# --- Security (virustotal.yml) ---
# VIRUSTOTAL_API_KEY=                   # https://www.virustotal.com/gui/my-apikey

# --- Apple Developer (release.yml, beta-release.yml) ---
# APPLE_ID=your-apple-id@email.com
# APPLE_APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx
# APPLE_TEAM_ID=XXXXXXXXXX
# APPLE_CERTIFICATE=base64-encoded-p12
# APPLE_CERTIFICATE_PASSWORD=your-cert-password

# --- Azure Trusted Signing (release.yml, beta-release.yml, test-azure-auth.yml) ---
# AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# AZURE_SUBSCRIPTION_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# AZURE_SIGNING_ACCOUNT=your-signing-account
# AZURE_SIGNING_PROFILE=your-cert-profile
# AZURE_SIGNING_ENDPOINT=https://eus.codesigning.azure.net
