# Autopolio API Dockerfile
FROM python:3.11-slim

WORKDIR /app

# Install system dependencies, Node.js, and uv
RUN apt-get update && apt-get install -y \
    gcc \
    curl \
    nodejs \
    npm \
    && rm -rf /var/lib/apt/lists/* \
    && curl -LsSf https://astral.sh/uv/install.sh | sh

# Install CLI tools in a single layer (optional — build continues if installation fails)
RUN curl -fsSL https://claude.ai/install.sh | bash 2>/dev/null || true; \
    npm install -g @google/gemini-cli @openai/codex 2>/dev/null || true

# Add uv and CLI paths to PATH
ENV PATH="/root/.local/bin:/root/.claude/local/bin:$PATH"
ENV PYTHONUNBUFFERED=1

# Install Python dependencies first (better layer caching — code changes don't invalidate)
COPY pyproject.toml uv.lock README.md ./
RUN uv sync --frozen --no-dev

# Copy application code (changes here don't re-install dependencies)
COPY api/ ./api/
COPY config/ ./config/
COPY alembic.ini ./
COPY scripts/docker-entrypoint.sh /app/docker-entrypoint.sh
RUN chmod +x /app/docker-entrypoint.sh

# Create data directories
RUN mkdir -p data result

# Expose port
EXPOSE 8000

# Entrypoint copies .env.init → .env (writable internal copy)
ENTRYPOINT ["/app/docker-entrypoint.sh"]

# Run the application
CMD ["uv", "run", "uvicorn", "api.main:app", "--host", "0.0.0.0", "--port", "8000"]
